{
  "name": "ethicalads.io",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "engines": {
    "npm": ">=10.0.0 <11.0.0",
    "node": ">=20.0.0 <21.0.0"
  },
  "scripts": {
    "build:js": "webpack --config webpack.config.js --mode=development --progress --color",
    "build:css": "tailwindcss -i ./static-src/css/index.css -o ./ethicalads-theme/static/dist/main.css",
    "build": "concurrently \"npm run build:js\" \"npm run build:css\"",
    "watch:js": "webpack --config webpack.config.js --mode=development --watch",
    "watch:css": "tailwindcss -i ./static-src/css/index.css -o ./ethicalads-theme/static/dist/main.css --watch",
    "watch": "concurrently \"npm run watch:js\" \"npm run watch:css\"",
    "dist:js": "webpack --config webpack.config.js --mode=production --progress --color",
    "dist:css": "tailwindcss -i ./static-src/css/index.css -o ./ethicalads-theme/static/dist/main.css --minify",
    "dist": "concurrently \"npm run dist:js\" \"npm run dist:css\"",
    "deploy": "npm run dist && gh-pages -d www",
    "lint": "prettier -c .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtfd/ethicalads.io.git"
  },
  "author": "Read the Docs, Inc.",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/rtfd/ethicalads.io/issues"
  },
  "homepage": "https://github.com/rtfd/ethicalads.io#readme",
  "dependencies": {
    "jquery": "^3.6.0",
    "knockout": "^3.5.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "concurrently": "^9.2.1",
    "gh-pages": "^4.0.0",
    "prettier": "^2.1.1",
    "tailwindcss": "^4.2.4",
    "webpack": "^5.76.0",
    "webpack-cli": "^4.9.1"
  }
}
